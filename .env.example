# ──────────────────────────────────────────────────────────────
# ENV TEMPLATE — copy to `.env` and fill in. Commit THIS file, never `.env`.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Database (PostgreSQL). Local dev example shown; use Neon pooled URL in prod.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/googlywoogly_dev?schema=public"

# Public base URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin auth (Auth.js). Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"

# First-admin bootstrap (consumed by prisma/seed.ts). Change before any real deploy.
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_PASSWORD=""

# On-demand revalidation webhook secret (any long random string)
REVALIDATE_SECRET=""

# Nightly analytics rollup cron secret (Vercel Cron sends it as a Bearer token)
CRON_SECRET=""

# WhatsApp number in international format, no '+' (e.g. 9198XXXXXXXX)
WHATSAPP_NUMBER=""
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# Cloudinary (media library + product image uploads). Signed direct-to-Cloudinary
# uploads: the API secret stays server-side and signs each upload; the browser
# uploads straight to Cloudinary (bytes never touch our server). Blank => the
# admin falls back to add-image-by-URL only. Find these in Cloudinary → Settings.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional convenience var Cloudinary prints (cloudinary://<key>:<secret>@<cloud>).
CLOUDINARY_URL=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Folder uploads are organized under in the Cloudinary library.
CLOUDINARY_UPLOAD_FOLDER="googlywoogly/products"

# Email — set RESEND_API_KEY (preferred) OR SMTP_* (Gmail/Workspace). Blank => console transport in dev.
RESEND_API_KEY=""
EMAIL_FROM="GooglyWoogly Art <orders@example.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Bot protection — Cloudflare Turnstile (free). Blank => disabled.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
